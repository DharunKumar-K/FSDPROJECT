{
  "version": 2,
  "buildCommand": "npm install --prefix ./frontend && npm run build --prefix ./frontend && npm install --prefix ./server",
  "outputDirectory": "frontend/build",
  "installCommand": "npm install",
  "framework": null,
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/server/server.js"
    },
    {
      "src": "^/(?!api).*",
      "dest": "/frontend/build/index.html"
    }
  ]
}
